# ── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── LLM & OCR (OpenRouter) ───────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-key-here
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── OCR Backend ──────────────────────────────────────────────────
# "openrouter" = cascade multi-model via OpenRouter (défaut recommandé)
# "trocr"      = TrOCR local CPU (nécessite torch + transformers)
OCR_BACKEND=openrouter

# ── OCR Cascade — seuils de confiance (0.0–1.0) ─────────────────
# Si un modèle free score < OCR_FREE_THRESHOLD  → essaie le modèle suivant
# Si tous les free < OCR_FREE_THRESHOLD          → passe à Claude Haiku
# Si Haiku < OCR_HAIKU_THRESHOLD                → passe à Claude Sonnet (final)
OCR_FREE_THRESHOLD=0.70
OCR_HAIKU_THRESHOLD=0.82

# ── Cascade de modèles (ordre fixe dans ocr_service.py) ──────────
# Tier 1 – Free (5 modèles) :
#   meta-llama/llama-3.2-11b-vision-instruct:free
#   qwen/qwen2-vl-7b-instruct:free
#   google/gemma-3-12b-it:free
#   microsoft/phi-4-multimodal-instruct:free
#   meta-llama/llama-4-scout:free
# Tier 2 – Mid   : anthropic/claude-3-haiku
# Tier 3 – Final : anthropic/claude-sonnet-4-5
